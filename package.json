    "generatehtmlreport": "npx playwright show-report",
    "runplaywrightparallel": "npx playwright test --workers=4",
    "runsmoketestcases": "npx playwright test --grep @smoke",
    "runregressionexcludesmoke": "npx playwright test --grep @regression --grep-invert @smoke"
